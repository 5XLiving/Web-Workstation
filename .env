# =========================
# Core backend
# =========================
APP_HOST=0.0.0.0
APP_PORT=5000

# =========================
# Engine select
# triposr or instantmesh
# =========================
IMAGE3D_ENGINE=triposr

# =========================
# Debug fallback
# 1 = use backend/storage/test_assets/sample.glb
# 0 = run real engine
# =========================
DEBUG_USE_FAKE_GLB=0

# =========================
# TripoSR
# =========================
TRIPOSR_REPO_DIR=C:\Users\Owner\Desktop\TripoSR
TRIPOSR_PYTHON_BIN=C:\Users\Owner\AppData\Local\Programs\Python\Python313\python.exe
TRIPOSR_BAKE_TEXTURE=0
TRIPOSR_TEXTURE_RESOLUTION=0
TRIPOSR_TIMEOUT_SECONDS=1800

# =========================
# InstantMesh
# =========================
INSTANTMESH_REPO_DIR=C:\Users\Owner\Desktop\InstantMesh
INSTANTMESH_PYTHON_BIN=C:\Users\Owner\AppData\Local\Programs\Python\Python313\python.exe
INSTANTMESH_CONFIG=configs/instant-mesh-large.yaml
INSTANTMESH_NO_REMBG=1
INSTANTMESH_EXPORT_TEXMAP=0
INSTANTMESH_SAVE_VIDEO=0
INSTANTMESH_TIMEOUT_SECONDS=3600
