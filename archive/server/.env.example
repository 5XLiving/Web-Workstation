# Environment variables for 5XLiving 3D Maker API

# Flask
SECRET_KEY=change-this-in-production-use-random-string
JWT_SECRET_KEY=change-this-jwt-key-in-production
FLASK_ENV=development
PORT=5000

# API Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Membership Tiers
FREE_DAILY_QUOTA=1
PAID_DAILY_QUOTA=100

# Mesh Generation
FREE_TRIANGLE_LIMIT=512
PAID_TRIANGLE_LIMIT=4096

# AI Image Generation (optional)
AI_ENABLED=false
# AI_API_KEY=your-api-key-here
# AI_MODEL=stable-diffusion-v1.5

# Storage
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=output
DATA_FOLDER=data

# CORS
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*,file://*
